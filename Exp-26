import cv2

# Step 1: Read the input video
cap = cv2.VideoCapture('samplev.mp4')

# Get video properties
fps = int(cap.get(cv2.CAP_PROP_FPS))
width = int(cap.get(cv2.CAP_PROP_FRAME_WIDTH))
height = int(cap.get(cv2.CAP_PROP_FRAME_HEIGHT))

# Step 2: Store frames in a list
frames = []

while True:
    ret, frame = cap.read()
    if not ret:
        break
    frames.append(frame)

cap.release()

# Step 3: Reverse the frames
frames.reverse()

# Step 4: Write reversed frames into output video
fourcc = cv2.VideoWriter_fourcc(*'XVID')
out = cv2.VideoWriter('reversed_output.avi', fourcc, fps, (width, height))

for frame in frames:
    out.write(frame)

out.release()

print("Reversed video saved successfully!")
