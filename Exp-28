import cv2

# Step 1: Load pre-trained vehicle cascade
car_cascade = cv2.CascadeClassifier('cars.xml')

# Step 2: Read input video
cap = cv2.VideoCapture('samplev.mp4')

while True:
    ret, frame = cap.read()
    if not ret:
        break

    # Step 3: Convert frame to grayscale
    gray = cv2.cvtColor(frame, cv2.COLOR_BGR2GRAY)

    # Step 4: Detect vehicles
    cars = car_cascade.detectMultiScale(
        gray,
        scaleFactor=1.1,
        minNeighbors=3,
        minSize=(60, 60)
    )

    # Step 5: Draw rectangles around vehicles
    for (x, y, w, h) in cars:
        cv2.rectangle(frame, (x, y), (x+w, y+h), (0, 0, 255), 2)
        cv2.putText(frame, "Vehicle", (x, y-10),
                    cv2.FONT_HERSHEY_SIMPLEX,
                    0.6, (0, 0, 255), 2)

    # Step 6: Display output
    cv2.imshow("Vehicle Detection", frame)

    if cv2.waitKey(30) & 0xFF == 27:  # Press ESC to exit
        break

cap.release()
cv2.destroyAllWindows()
